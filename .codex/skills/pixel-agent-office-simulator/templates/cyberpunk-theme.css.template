/* ============================================================
   사이버펑크 오피스 시뮬레이터 CSS 테마 템플릿
   사용법: client/src/index.css 에 병합
   ============================================================ */

/* 색상 변수 */
:root {
  --neon-green: #00ff41;
  --neon-cyan: #22d3ee;
  --neon-purple: #a78bfa;
  --neon-yellow: #f5c518;
  --dark-bg: #050810;
  --panel-bg: rgba(10, 14, 26, 0.95);
  --border-glow: rgba(0, 255, 65, 0.12);
}

/* 스캔라인 오버레이 */
.scanlines {
  position: fixed;
  inset: 0;
  background: repeating-linear-gradient(
    0deg,
    transparent, transparent 2px,
    rgba(0,0,0,0.07) 2px, rgba(0,0,0,0.07) 4px
  );
  pointer-events: none;
  z-index: 9999;
}

/* 사이버펑크 그리드 */
.cyber-grid {
  background-image:
    linear-gradient(rgba(0,255,65,0.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,255,65,0.025) 1px, transparent 1px);
  background-size: 32px 32px;
}

/* 픽셀 폰트 헤더 */
.pixel-header {
  font-family: 'Press Start 2P', monospace;
  color: var(--neon-green);
  text-shadow: 0 0 12px var(--neon-green);
}

/* 네온 테두리 패널 */
.neon-panel {
  background: var(--panel-bg);
  border: 1px solid var(--border-glow);
  box-shadow: 0 0 20px rgba(0,255,65,0.05);
}

/* 에이전트 애니메이션 키프레임 */
@keyframes charBob {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-2px); }
}

@keyframes agentRing {
  0% { transform: translate(-50%,-50%) scale(0.6); opacity: 0.7; border-width: 2px; }
  100% { transform: translate(-50%,-50%) scale(1.6); opacity: 0; border-width: 1px; }
}

@keyframes workBarFill {
  0% { width: 0; }
  90% { width: 96%; }
  100% { width: 100%; }
}

@keyframes ledBlink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

@keyframes bubbleIn {
  from { opacity: 0; transform: translateX(-50%) translateY(4px) scale(0.95); }
  to { opacity: 1; transform: translateX(-50%) translateY(0) scale(1); }
}

@keyframes sparkFloat {
  0% { opacity: 1; transform: translate(0, 0) scale(1); }
  100% { opacity: 0; transform: translate(0, -40px) scale(0.3); }
}

@keyframes beamPulse {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 1; }
}

@keyframes pixelPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.6; }
}
